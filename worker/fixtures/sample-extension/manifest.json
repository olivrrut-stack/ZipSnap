{
  "manifest_version": 3,
  "name": "FocusDash",
  "version": "1.0.0",
  "description": "Track your focus sessions and daily productivity streaks right from your toolbar.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "FocusDash"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}
