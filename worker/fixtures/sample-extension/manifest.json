{
  "manifest_version": 3,
  "name": "ZipSnap Sample Extension",
  "version": "1.0.0",
  "description": "A sample extension for trying out ZipSnap's auto-capture feature.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "ZipSnap Test"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}
